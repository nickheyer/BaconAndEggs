# WiFi creds
WIFI_SSID = YourNetworkName
WIFI_PASSWORD = YourPassword

# Default targets (format: name=MAC,IP;name=MAC — IP is optional)
# DEFAULT_SERVERS = mypc=AA:BB:CC:DD:EE:FF,192.168.1.100;nas=11:22:33:44:55:66
DEFAULT_SERVERS =

# Auto-wake all on boot
DEFAULT_AUTOWAKE = 0

# Debug
# SERIAL_PORT = /dev/tty.usbmodem141101
# SERIAL_BAUD = 115200
