# WiFi creds
WIFI_SSID = YourNetworkName
WIFI_PASSWORD = YourPassword

# Default targets (format: name=MAC,IP;name=MAC — IP is optional)
# DEFAULT_SERVERS = mypc=AA:BB:CC:DD:EE:FF,192.168.1.100;nas=11:22:33:44:55:66
DEFAULT_SERVERS =

# Auto-wake all on boot
DEFAULT_AUTOWAKE = 0

# Timezone (UTC offset in minutes, e.g. -300 for EST, 60 for CET)
DEFAULT_UTC_OFFSET = 0

# NTP server
DEFAULT_NTP_SERVER = pool.ntp.org

# MQTT broker (leave empty to disable)
DEFAULT_MQTT_HOST =
DEFAULT_MQTT_PORT = 1883
DEFAULT_MQTT_USER =
DEFAULT_MQTT_PASS =

# Webhook URL (leave empty to disable)
# Compatible with ntfy.sh, Discord, Slack, etc.
DEFAULT_WEBHOOK_URL =

# Debug
# SERIAL_PORT = /dev/tty.usbmodem141101
# SERIAL_BAUD = 115200
